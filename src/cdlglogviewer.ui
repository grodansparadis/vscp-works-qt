    <y>0</y>
    <width>1000</width>
    <height>650</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>Application Log Viewer</string>
  </property>
  <layout class="QVBoxLayout" name="verticalLayout" stretch="0,1,0">
