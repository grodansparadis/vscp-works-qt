   </property>
   <property name="topMargin">
    <number>8</number>
   </property>
   <property name="rightMargin">
    <number>8</number>
   </property>
   <property name="bottomMargin">
    <number>8</number>
   </property>

   <!-- Top filter bar -->
   <item>
    <layout class="QHBoxLayout" name="filterLayout">
     <item>
      <widget class="QLabel" name="labelLevel">
       <property name="text">
        <string>Level:</string>
       </property>
      </widget>
     </item>
