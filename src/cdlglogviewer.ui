       </property>
       <property name="toolTip">
        <string>Reload the log file</string>
       </property>
      </widget>
     </item>
    </layout>
   </item>

   <!-- Log table -->
   <item>
    <widget class="QTableWidget" name="tableLog">
     <property name="alternatingRowColors">
